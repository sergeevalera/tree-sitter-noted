{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "noted",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "heading"
          },
          {
            "type": "SYMBOL",
            "name": "callout_block"
          },
          {
            "type": "SYMBOL",
            "name": "fenced_code_block"
          },
          {
            "type": "SYMBOL",
            "name": "list_item"
          },
          {
            "type": "SYMBOL",
            "name": "thematic_break"
          },
          {
            "type": "SYMBOL",
            "name": "blank_line"
          },
          {
            "type": "SYMBOL",
            "name": "paragraph_line"
          }
        ]
      }
    },
    "heading": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "PATTERN",
            "value": "#{1,6} "
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_inline"
          }
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "callout_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "> [!"
        },
        {
          "type": "FIELD",
          "name": "callout_type",
          "content": {
            "type": "SYMBOL",
            "name": "callout_type_name"
          }
        },
        {
          "type": "STRING",
          "value": "]"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": " "
                },
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SYMBOL",
                    "name": "_inline"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "blockquote_continuation"
          }
        }
      ]
    },
    "callout_type_name": {
      "type": "PATTERN",
      "value": "[A-Za-z][A-Za-z0-9]*"
    },
    "blockquote_continuation": {
      "type": "PATTERN",
      "value": "> [^\\n]*\\n"
    },
    "fenced_code_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "fence_start",
          "content": {
            "type": "PATTERN",
            "value": "`{3}[^\\n]*"
          }
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "code",
              "content": {
                "type": "PATTERN",
                "value": "(?:[^`]|`{1,2}[^`])+"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "```"
        },
        {
          "type": "PATTERN",
          "value": "[^\\n]*"
        },
        {
          "type": "PATTERN",
          "value": "\\n?"
        }
      ]
    },
    "list_item": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[ \\t]*(?:[-*+]|\\d+[.)]) "
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "checkbox",
              "content": {
                "type": "SYMBOL",
                "name": "checkbox"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_inline"
          }
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "checkbox": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "[ ] "
          },
          {
            "type": "STRING",
            "value": "[x] "
          },
          {
            "type": "STRING",
            "value": "[X] "
          }
        ]
      }
    },
    "paragraph_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "_inline"
          }
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "blank_line": {
      "type": "STRING",
      "value": "\n"
    },
    "thematic_break": {
      "type": "PATTERN",
      "value": "(?:-{3,}|={3,}|_{3,}) *\\n"
    },
    "_inline": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "embed"
        },
        {
          "type": "SYMBOL",
          "name": "wikilink"
        },
        {
          "type": "SYMBOL",
          "name": "tag"
        },
        {
          "type": "SYMBOL",
          "name": "bold"
        },
        {
          "type": "SYMBOL",
          "name": "italic"
        },
        {
          "type": "SYMBOL",
          "name": "inline_code"
        },
        {
          "type": "SYMBOL",
          "name": "link"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        }
      ]
    },
    "wikilink": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "[["
        },
        {
          "type": "FIELD",
          "name": "target",
          "content": {
            "type": "SYMBOL",
            "name": "wikilink_target"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "|"
                },
                {
                  "type": "FIELD",
                  "name": "alias",
                  "content": {
                    "type": "SYMBOL",
                    "name": "wikilink_alias"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]]"
        }
      ]
    },
    "wikilink_target": {
      "type": "PATTERN",
      "value": "[^\\]|\\n]+"
    },
    "wikilink_alias": {
      "type": "PATTERN",
      "value": "[^\\]\\n]+"
    },
    "embed": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "![["
        },
        {
          "type": "FIELD",
          "name": "target",
          "content": {
            "type": "SYMBOL",
            "name": "embed_target"
          }
        },
        {
          "type": "STRING",
          "value": "]]"
        }
      ]
    },
    "embed_target": {
      "type": "PATTERN",
      "value": "[^\\]\\n]+"
    },
    "tag": {
      "type": "PATTERN",
      "value": "#[A-Za-z][\\w\\-\\/]*"
    },
    "bold": {
      "type": "PREC",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "TOKEN",
            "content": {
              "type": "PREC",
              "value": 2,
              "content": {
                "type": "STRING",
                "value": "**"
              }
            }
          },
          {
            "type": "REPEAT1",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "inline_code"
                },
                {
                  "type": "SYMBOL",
                  "name": "italic"
                },
                {
                  "type": "SYMBOL",
                  "name": "bold_text"
                }
              ]
            }
          },
          {
            "type": "TOKEN",
            "content": {
              "type": "PREC",
              "value": 2,
              "content": {
                "type": "STRING",
                "value": "**"
              }
            }
          }
        ]
      }
    },
    "bold_text": {
      "type": "PATTERN",
      "value": "[^*`\\n]+"
    },
    "italic": {
      "type": "PREC",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "*"
          },
          {
            "type": "REPEAT1",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "inline_code"
                },
                {
                  "type": "SYMBOL",
                  "name": "italic_text"
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "*"
          }
        ]
      }
    },
    "italic_text": {
      "type": "PATTERN",
      "value": "[^*`\\n]+"
    },
    "inline_code": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "`"
        },
        {
          "type": "PATTERN",
          "value": "[^`\\n]+"
        },
        {
          "type": "STRING",
          "value": "`"
        }
      ]
    },
    "link": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "FIELD",
          "name": "text",
          "content": {
            "type": "PATTERN",
            "value": "[^\\]\\n]+"
          }
        },
        {
          "type": "STRING",
          "value": "]("
        },
        {
          "type": "FIELD",
          "name": "url",
          "content": {
            "type": "PATTERN",
            "value": "[^)\\n]+"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "text": {
      "type": "PATTERN",
      "value": "[^\\[\\]!*`#\\n]+|[!#]"
    }
  },
  "extras": [],
  "conflicts": [
    [
      "bold",
      "italic"
    ],
    [
      "paragraph_line",
      "list_item"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}